<Window x:Class="EsnafPos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Esnaf POS"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        MinHeight="600" MinWidth="1024"
        Background="{StaticResource LightBrush}"
        Icon="pack://application:,,,/esnafpos.ico"
        >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- UST BAR -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LOGO -->
                <TextBlock x:Name="TxtAppName" Grid.Column="0"
                           Text="Esnaf POS"
                           FontSize="26" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <!-- NAViGASYON BUTONLARI -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">

                    <Button Height="46" Padding="28,0" Margin="6,0"
                            Style="{StaticResource DarkButton}"
                            Click="BtnTables_Click">
                        <TextBlock Text="Masalar" FontSize="17"
                                   Foreground="White" FontWeight="SemiBold"/>
                    </Button>

                    <Button x:Name="BtnReports"
                            Height="46" Padding="28,0" Margin="6,0"
                            Style="{StaticResource DarkButton}"
                            Visibility="Collapsed"
                            Click="BtnReports_Click">
                        <TextBlock Text="Raporlar" FontSize="17"
                                   Foreground="White" FontWeight="SemiBold"/>
                    </Button>

                    <Button x:Name="BtnAdmin"
                            Height="46" Padding="28,0" Margin="6,0"
                            Style="{StaticResource DarkButton}"
                            Visibility="Collapsed"
                            Click="BtnAdmin_Click">
                        <TextBlock Text="Yonetim" FontSize="17"
                                   Foreground="White" FontWeight="SemiBold"/>
                    </Button>

                </StackPanel>

                <!-- KULLANICI & ROL & CIKIS -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock x:Name="TxtCurrentUser"
                                   Foreground="White" FontSize="16"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtCurrentRole"
                                   Foreground="#BDC3C7" FontSize="13"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Button Height="42" Padding="20,0"
                            Style="{StaticResource DangerButton}"
                            Click="BtnLogout_Click">
                        <TextBlock Text="Cikis" FontSize="17"
                                   Foreground="White" FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- iCERiK ALANI -->
        <Frame x:Name="MainFrame" Grid.Row="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
