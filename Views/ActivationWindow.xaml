<Window x:Class="EsnafPos.Views.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EsnafPos - Aktivasyon"
        Height="480" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1A2E">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
        <StackPanel>

            <!-- Logo -->
            <Border Width="72" Height="72" CornerRadius="20"
                    HorizontalAlignment="Center" Margin="0,0,0,20"
                    Background="{StaticResource AccentBrush}">
                <TextBlock Text="⚡" FontSize="32"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="EsnafPos Aktivasyon" FontSize="26" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Aktivasyon kodunuzu girerek uygulamayı etkinleştirin."
                       FontSize="14" Foreground="#8899AA"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap" Margin="0,0,0,36"/>

            <!-- Kod Girişi -->
            <TextBlock Text="Aktivasyon Kodu" FontSize="13" FontWeight="SemiBold"
                       Foreground="#CBD5E1" Margin="0,0,0,8"/>
            <TextBox x:Name="TxtCode"
                     Height="52" FontSize="18" FontFamily="Consolas"
                     Foreground="White" CaretBrush="White"
                     Background="#16213E" BorderBrush="#2D3A50" BorderThickness="1"
                     Padding="16,0" VerticalContentAlignment="Center"
                     CharacterCasing="Upper"
                     Tag="CIKO-XXXX-XXXX"/>

            <!-- Hata mesajı -->
            <TextBlock x:Name="TxtError"
                       Foreground="#E94560" FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0" Visibility="Collapsed"
                       TextWrapping="Wrap" TextAlignment="Center"/>

            <!-- Aktive Et butonu -->
            <Button x:Name="BtnActivate"
                    Height="52" Margin="0,20,0,0"
                    Background="{StaticResource AccentBrush}"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnActivate_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="10"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock x:Name="TxtBtnLabel"
                           Text="Aktive Et" FontSize="16" FontWeight="SemiBold"
                           Foreground="White"/>
            </Button>

            <StackPanel HorizontalAlignment="Center" Margin="0,16,0,0">
                <TextBlock Text="Aktivasyon kodu için satıcınızla iletişime geçin."
                           FontSize="12" Foreground="#4A6480"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock Text="WhatsApp: 0507 572 78 16"
                           FontSize="13" FontWeight="SemiBold" Foreground="#8899AA"
                           HorizontalAlignment="Center" Margin="0,6,0,0"
                           TextAlignment="Center"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
