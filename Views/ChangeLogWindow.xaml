<Window x:Class="EsnafPos.Views.ChangeLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Urun Degisim Kayitlari" Height="720" Width="940"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F8">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Urun Degisim Kayitlari"
                   FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,20"/>

        <!-- FiLTRE -->
        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="20,16" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Tarih:" VerticalAlignment="Center"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,12,0"/>
                <DatePicker x:Name="DpFilter" FontSize="15" Width="180" Height="44" Margin="0,0,16,0"/>
                <Button Style="{StaticResource PrimaryButton}"
                        Height="44" FontSize="15" Padding="24,0" Margin="0,0,10,0"
                        Click="BtnFilter_Click">
                    <TextBlock Text="Filtrele" Foreground="White" FontWeight="SemiBold"/>
                </Button>
                <Button Style="{StaticResource SecondaryButton}"
                        Height="44" FontSize="15" Padding="20,0"
                        Click="BtnAll_Click">
                    <TextBlock Text="Tumunu Goster" Foreground="White" FontWeight="SemiBold"/>
                </Button>
                <Border Background="#EBF5FB" CornerRadius="10" Padding="16,8" Margin="16,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="TxtCount" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- LiSTE -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="IcLogs">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="14"
                                Margin="0,0,0,12" Padding="0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2"
                                                  Color="#CCCCCC" Opacity="0.12"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>

                                <!-- Sol renk seridi: Degisim=turuncu, Iptal=kirmizi -->
                                <Border Grid.Column="0" CornerRadius="14,0,0,14">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Reason}" Value="Urun Iptali">
                                                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <!-- Orta: detaylar -->
                                <Grid Grid.Column="1" Margin="20,16,16,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Sol: Masa + Saat -->
                                    <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TableName}"
                                                   FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   Margin="0,0,0,6"/>
                                        <Border Background="#EBF5FB" CornerRadius="6" Padding="8,4"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                                       FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Sag: Urun detayi -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Border Background="{StaticResource LightBrush}"
                                                    CornerRadius="6" Padding="8,3" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding QuantityRemoved, StringFormat='{}{0}x'}"
                                                           FontSize="14" FontWeight="Bold"
                                                           Foreground="{StaticResource PrimaryBrush}"/>
                                            </Border>
                                            <TextBlock FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding ProductName, Mode=OneWay}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Portion, Mode=OneWay}"
                                                     Foreground="{StaticResource MutedBrush}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Kasiyer:" FontSize="13"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding CashierName}" FontSize="13"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Sag: Sebep + Tutar -->
                                <Border Grid.Column="2" CornerRadius="0,14,14,0" Padding="16,16">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFF8F0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Reason}" Value="Urun Iptali">
                                                    <Setter Property="Background" Value="#FFF0F0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Border CornerRadius="8" Padding="12,6" Margin="0,0,0,10"
                                                HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Reason}" Value="Urun Iptali">
                                                            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Reason}" Foreground="White"
                                                       FontSize="13" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock FontSize="18" FontWeight="Bold"
                                                   HorizontalAlignment="Center">
                                            <TextBlock.Text>
                                                <Binding Path="UnitPrice" StringFormat="{}{0:N2} TL"/>
                                            </TextBlock.Text>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Reason}" Value="Urun Iptali">
                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>


        <!-- SAYFALAMA -->
        <Border Grid.Row="3" Background="White" CornerRadius="12" Padding="16,10" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtPageInfo" Grid.Column="1"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnPrev" Content="◀ Önceki"
                            Style="{StaticResource SecondaryButton}"
                            Height="36" FontSize="13" Padding="16,0" Margin="0,0,8,0"
                            Click="BtnPrev_Click"/>
                    <Button x:Name="BtnNext" Content="Sonraki ▶"
                            Style="{StaticResource PrimaryButton}"
                            Height="36" FontSize="13" Padding="16,0"
                            Click="BtnNext_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Button Grid.Row="4" Style="{StaticResource SecondaryButton}"
                Height="48" FontSize="16" Padding="32,0"
                HorizontalAlignment="Right" Margin="0,16,0,0"
                Click="BtnClose_Click">
            <TextBlock Text="Kapat" Foreground="White" FontWeight="SemiBold"/>
        </Button>
    </Grid>
</Window>
