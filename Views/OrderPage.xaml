<Page x:Class="EsnafPos.Views.OrderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Sipariş" Background="{StaticResource LightBrush}">

    <Page.Resources>
        <!-- Urun butonu template -->
        <ControlTemplate x:Key="ProductButtonTemplate" TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="10"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EAF6EE"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#27AE60"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Page.Resources>

    <!-- Ana Grid -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- SOL TARAF: MENU -->
        <Grid Grid.Column="0" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- BASLIK + DUZENLE BUTONU -->
            <Border Grid.Row="0" CornerRadius="14" Margin="0,0,0,16"
                    Padding="18,12"
                    Background="White">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#CCCCCC" Opacity="0.12"/>
                </Border.Effect>
            <Grid>
                <TextBlock Text="{Binding CurrentTable.Name, StringFormat='Masa: {0}'}"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnMoveTable"
                            Height="42" MinWidth="130" Padding="0" Margin="0,0,10,0"
                            BorderThickness="0" Background="#2980B9"
                            Click="BtnMoveTable_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="⇄ Taşı" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    </Button>
                    <Button x:Name="BtnMergeTable"
                            Height="42" MinWidth="150" Padding="0" Margin="0,0,10,0"
                            BorderThickness="0" Background="#8E44AD"
                            Click="BtnMergeTable_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="⊕ Birleştir" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    </Button>
                    <Button x:Name="BtnEditMode"
                            Height="42" MinWidth="140" Padding="0"
                            BorderThickness="0"
                            Click="BtnEditMode_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
            </Border>

            <!-- KANAL BUTONLARI -->
            <StackPanel Grid.Row="1" x:Name="PanelChannels"
                        Orientation="Horizontal" Margin="0,0,0,16"/>

            <!-- KATEGORiLER (sol) + URUNLER (sag) -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Dikey Kategori Listesi -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PanelCategories"/>
                </ScrollViewer>

                <!-- Urun Alani -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>

                    <!-- Urunler WrapPanel + Ghost Canvas -->
                    <Grid Grid.Row="0">
                        <ScrollViewer x:Name="ProductScrollViewer"
                                      VerticalScrollBarVisibility="Auto">
                            <WrapPanel x:Name="PanelProducts"
                                       HorizontalAlignment="Left"
                                       PreviewMouseLeftButtonDown="PanelProducts_MouseDown"
                                       MouseMove="PanelProducts_MouseMove"
                                       PreviewMouseLeftButtonUp="PanelProducts_MouseUp"
                                       PreviewTouchDown="PanelProducts_TouchDown"
                                       TouchMove="PanelProducts_TouchMove"
                                       TouchUp="PanelProducts_TouchUp"/>
                        </ScrollViewer>
                    </Grid>

                    <!-- Porsiyon modu seçici şeridi -->
                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 1.5 solda -->
                        <Button x:Name="BtnModeBucuk" Grid.Column="0"
                                Height="64" BorderThickness="0"
                                Click="BtnModeBucuk_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BucukBorder" Background="#2980B9" CornerRadius="12">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="6" ShadowDepth="2"
                                                              Color="#1A5276" Opacity="0.4"/>
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BucukBorder" Property="Opacity" Value="0.88"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="BucukBorder" Property="Background" Value="#1A5276"/>
                                            <Setter TargetName="BucukBorder" Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock x:Name="TxtModeBucuk" Text="1.5 Porsiyon"
                                       FontSize="17" FontWeight="Bold"
                                       Foreground="White"/>
                        </Button>

                        <!-- Az sağda -->
                        <Button x:Name="BtnModeAz" Grid.Column="2"
                                Height="64" BorderThickness="0"
                                Click="BtnModeAz_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="AzBorder" Background="#E67E22" CornerRadius="12">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="6" ShadowDepth="2"
                                                              Color="#A04000" Opacity="0.4"/>
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="AzBorder" Property="Opacity" Value="0.88"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="AzBorder" Property="Background" Value="#A04000"/>
                                            <Setter TargetName="AzBorder" Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock x:Name="TxtModeAz" Text="Az"
                                       FontSize="17" FontWeight="Bold"
                                       Foreground="White"/>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- Ghost drag canvas - tum sayfanin ustunde -->
        <Canvas x:Name="DragCanvas" Grid.ColumnSpan="2"
                IsHitTestVisible="False" Panel.ZIndex="999"/>

        <!-- SAG TARAF: SiPARiS OZETI -->
        <Border Grid.Column="1" Background="White"
                BorderBrush="#BDC3C7" BorderThickness="1,0,0,0">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Sipariş Özeti"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="0,0,0,20"/>

                <ListView Grid.Row="1" ItemsSource="{Binding OrderItems}"
                          BorderThickness="0" Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#ECF0F1" BorderThickness="0,0,0,1" Padding="0,10">
                                <StackPanel>
                                    <!-- Satır 1: Ürün adı -->
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="Bold" FontSize="14"
                                               Foreground="{StaticResource TextBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,6"/>
                                    <!-- Satır 2: Adet/fiyat solda, toplam + butonlar sağda -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" FontSize="13"
                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                   VerticalAlignment="Center">
                                            <Run Text="{Binding Quantity}"/>
                                            <Run Text="x"/>
                                            <Run Text="{Binding PriceSnapshot, StringFormat='{}{0:N2} TL'}"/>
                                        </TextBlock>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding LineTotal, StringFormat='{}{0:N2} TL'}"
                                                       FontWeight="Bold" FontSize="14"
                                                       Foreground="{StaticResource TextBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                            <Button Width="36" Height="36"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Padding="0" Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.AddQuantityCommand,
                                                        RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="+" FontSize="20" Foreground="White"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Button>
                                            <Button Width="36" Height="36"
                                                    Style="{StaticResource DangerButton}"
                                                    Padding="0" VerticalAlignment="Center"
                                                    Command="{Binding DataContext.RemoveItemCommand,
                                                        RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="−" FontSize="20" Foreground="White"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Separator Grid.Row="2" Margin="0,16"/>

                <Grid Grid.Row="3" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="TOPLAM" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding TotalAmount, StringFormat='{}{0:N2} TL'}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Row="4" Margin="0,0,0,8">
                    <Button Height="62" FontSize="19" Margin="0,0,0,10"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding RequestPaymentCommand}">
                        <TextBlock Text="Ödeme Al" FontSize="19"
                                   Foreground="White" FontWeight="Bold"/>
                    </Button>
                    <Button Height="52" FontSize="17" Margin="0,0,0,10"
                            Style="{StaticResource WarningButton}"
                            Command="{Binding PrintCheckCommand}">
                        <TextBlock Text="Adisyon Yazdır" FontSize="17"
                                   Foreground="White" FontWeight="Bold"/>
                    </Button>
                    <Button Height="52" FontSize="17"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnBack_Click">
                        <TextBlock Text="Geri" FontSize="17"
                                   Foreground="White" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
