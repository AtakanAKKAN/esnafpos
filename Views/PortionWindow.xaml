<Window x:Class="EsnafPos.Views.PortionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Porsiyon Sec" Height="600" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource LightBrush}">

    <Border Background="White" CornerRadius="14" Margin="24">
        <StackPanel Margin="36">

            <TextBlock x:Name="TxtProductName"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- AZ PORSIYON -->
            <Button x:Name="BtnAz"
                    Style="{StaticResource DarkButton}"
                    Height="68" Margin="0,0,0,14"
                    Visibility="Collapsed"
                    Click="BtnAz_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Az Porsiyon"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White" Margin="0,0,20,0"/>
                    <TextBlock x:Name="TxtAzPrice"
                               FontSize="18" Foreground="#BDC3C7"/>
                </StackPanel>
            </Button>

            <!-- TAM PORSIYON -->
            <Button x:Name="BtnTam"
                    Style="{StaticResource PrimaryButton}"
                    Height="68" Margin="0,0,0,14"
                    Click="BtnTam_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Tam Porsiyon"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White" Margin="0,0,20,0"/>
                    <TextBlock x:Name="TxtTamPrice"
                               FontSize="18" Foreground="White"/>
                </StackPanel>
            </Button>

            <!-- 1.5 PORSIYON -->
            <Button x:Name="BtnBucuk"
                    Style="{StaticResource WarningButton}"
                    Height="68" Margin="0,0,0,32"
                    Visibility="Collapsed"
                    Click="BtnBucuk_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="1.5 Porsiyon"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White" Margin="0,0,20,0"/>
                    <TextBlock x:Name="TxtBucukPrice"
                               FontSize="18" Foreground="White"/>
                </StackPanel>
            </Button>

            <Separator Margin="0,0,0,20"/>

            <Button Style="{StaticResource SecondaryButton}"
                    Height="52" FontSize="17"
                    Click="BtnCancel_Click">
                <TextBlock Text="Iptal" Foreground="White" FontWeight="SemiBold"/>
            </Button>

        </StackPanel>
    </Border>
</Window>