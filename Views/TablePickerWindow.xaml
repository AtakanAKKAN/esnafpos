<Window x:Class="EsnafPos.Views.TablePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EsnafPos.Views"
        Title="Masa Seç" Height="510" Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F4F8">

    <Window.Resources>
        <!-- Boş masa kartı -->
        <DataTemplate DataType="{x:Type local:TablePickerTableItem}">
            <Button Width="160" Height="86" Margin="8"
                    Tag="{Binding}" Click="BtnTableItem_Click"
                    BorderThickness="0" Background="Transparent" Padding="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="White" CornerRadius="12" x:Name="CardBorder">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="3" Color="#1B2A4A" Opacity="0.12"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="12,0,0,12" Background="#16A34A"/>
                                <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="#1F2A37"/>
                                    <TextBlock Text="Boş Masa" FontSize="12" Foreground="#16A34A" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <!-- Veresiye müşteri kartı -->
        <DataTemplate DataType="{x:Type local:TablePickerVeresiyeItem}">
            <Button Width="160" Height="86" Margin="8"
                    Tag="{Binding}" Click="BtnTableItem_Click"
                    BorderThickness="0" Background="Transparent" Padding="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="White" CornerRadius="12" x:Name="CardBorder">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="3" Color="#1B2A4A" Opacity="0.12"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="12,0,0,12" Background="#8E44AD"/>
                                <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CustomerName}" FontSize="15" FontWeight="Bold"
                                               Foreground="#1F2A37" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N2} TL'}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#8E44AD" Margin="0,4,0,0"/>
                                    <TextBlock Text="Veresiye" FontSize="11"
                                               Foreground="#BDC3C7" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TxtTitle" FontSize="20" FontWeight="Bold"
                       Foreground="#1F2A37" Margin="0,0,0,6"/>
            <TextBlock x:Name="TxtSubtitle" FontSize="14"
                       Foreground="{StaticResource SubtleTextBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="IcItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2" Content="İptal"
                Style="{StaticResource SecondaryButton}"
                Height="44" FontSize="15" Padding="28,0"
                HorizontalAlignment="Right" Margin="0,16,0,0"
                Click="BtnCancel_Click"/>
    </Grid>
</Window>
