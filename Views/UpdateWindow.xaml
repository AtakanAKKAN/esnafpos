<Window x:Class="EsnafPos.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Güncelleme Mevcut"
        Height="380" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1A2E">

    <Grid Margin="40">
        <StackPanel>
            <!-- İkon + Başlık -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Border Width="48" Height="48" CornerRadius="12"
                        Background="{StaticResource AccentBrush}"
                        Margin="0,0,16,0">
                    <TextBlock Text="⬆" FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TxtTitle"
                               Text="Yeni Güncelleme Mevcut"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="TxtVersion"
                               FontSize="13" Foreground="#8899AA"/>
                </StackPanel>
            </StackPanel>

            <!-- Zorunlu uyarı -->
            <Border x:Name="PanelForced"
                    Background="#2D1515" CornerRadius="8"
                    Padding="12,10" Margin="0,0,0,12"
                    Visibility="Collapsed">
                <TextBlock Text="⚠ Bu güncelleme zorunludur. Devam etmek için güncelleme yapmanız gerekmektedir."
                           Foreground="#E94560" FontSize="13"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Sürüm notları -->
            <Border Background="#16213E" CornerRadius="8"
                    Padding="12" Margin="0,0,0,20" MaxHeight="120">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtReleaseNotes"
                               Foreground="#94A3B8" FontSize="13"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <!-- Progress bar -->
            <ProgressBar x:Name="ProgressBar"
                         Height="8" Margin="0,0,0,8"
                         Visibility="Collapsed"
                         Background="#16213E"
                         Foreground="{StaticResource AccentBrush}"/>
            <TextBlock x:Name="TxtProgress"
                       FontSize="12" Foreground="#8899AA"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"
                       Visibility="Collapsed"/>

            <!-- Butonlar -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnLater"
                        Grid.Column="0" Height="46"
                        Content="Sonra Hatırlat"
                        Background="#16213E" BorderThickness="0"
                        Foreground="#8899AA" FontSize="14"
                        Cursor="Hand" Click="BtnLater_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnUpdate"
                        Grid.Column="2" Height="46"
                        Background="{StaticResource AccentBrush}"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnUpdate_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock x:Name="TxtUpdateBtn"
                               Text="Güncelle ve Yeniden Başlat"
                               Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
