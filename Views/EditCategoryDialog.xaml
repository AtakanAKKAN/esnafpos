<Window x:Class="EsnafPos.Views.EditCategoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kategori Düzenle" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F4F8">

    <Border Background="White" CornerRadius="14" Margin="20" Padding="28">
        <StackPanel>
            <TextBlock FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,20">
                <Run Text="Kategori Düzenle — "/>
                <Run x:Name="RunCategoryName" Foreground="{StaticResource AccentBrush}"/>
            </TextBlock>

            <TextBlock Text="Kategori Adı" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtName" Height="48" FontSize="15" Margin="0,0,0,16"/>

            <TextBlock Text="Kanal" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,6"/>
            <ComboBox x:Name="CboChannel" Height="48" FontSize="15" Margin="0,0,0,28"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="Masa"     Tag="Masa"/>
                <ComboBoxItem Content="Kurye"    Tag="Kurye"/>
                <ComboBoxItem Content="Bekci"    Tag="Bekci"/>
                <ComboBoxItem Content="Trendyol" Tag="Trendyol"/>
                <ComboBoxItem Content="Diger"    Tag="Diger"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Height="48" Padding="24,0" Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnCancel_Click">
                    <TextBlock Text="İptal" Foreground="White" FontWeight="SemiBold"/>
                </Button>
                <Button Height="48" Padding="28,0"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnSave_Click">
                    <TextBlock Text="Kaydet" Foreground="White" FontWeight="SemiBold" FontSize="15"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
