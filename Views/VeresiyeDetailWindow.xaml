<Window x:Class="EsnafPos.Views.VeresiyeDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Veresiye Detay" Height="700" Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource LightBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- BASLIK -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Border Width="56" Height="56" CornerRadius="28"
                    Background="#8E44AD" Margin="0,0,16,0">
                <TextBlock x:Name="TxtInitial"
                           FontSize="24" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TxtCustomerName"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock x:Name="TxtTotalDebt"
                           FontSize="15" Foreground="#8E44AD" FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>

        <!-- SEC HEPSI -->
        <Button Grid.Row="1" Height="44" FontSize="14" Margin="0,0,0,12"
                Background="#8E44AD" BorderThickness="0"
                Click="BtnSelectAll_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <TextBlock Text="Tüm Ürünleri Seç" Foreground="White" FontWeight="Bold" FontSize="15"/>
        </Button>

        <!-- URUN LiSTESi -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="IcItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#ECF0F1" BorderThickness="0,0,0,1" Padding="4,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   Text="{Binding DisplayName}"/>
                                        <TextBlock FontSize="13" Foreground="{StaticResource MutedBrush}">
                                            <Run Text="{Binding UnitPrice, StringFormat='{}{0:N2} TL', Mode=OneWay}"/>
                                            <Run Text=" x "/>
                                            <Run Text="{Binding RemainingQuantity, Mode=OneWay}"/>
                                            <Run Text=" kalan"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="{StaticResource LightBrush}"
                                                CornerRadius="8" Padding="10,4"
                                                VerticalAlignment="Center" Margin="0,0,10,0">
                                            <TextBlock FontSize="14" FontWeight="Bold"
                                                       Foreground="#8E44AD"
                                                       Text="{Binding RowTotal, StringFormat='{}{0:N2} TL', Mode=OneWay}"/>
                                        </Border>

                                        <!-- AZALT -->
                                        <Button Width="38" Height="38" Background="#E74C3C" BorderThickness="0"
                                                Tag="{Binding}" Click="BtnDecrease_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock Text="−" Foreground="White" FontSize="22" FontWeight="Bold"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Button>

                                        <!-- MIKTAR -->
                                        <Border Width="44" Height="38" Background="White"
                                                BorderBrush="#DEE2E6" BorderThickness="1"
                                                CornerRadius="6" Margin="6,0">
                                            <TextBlock Text="{Binding SelectedQuantity, Mode=OneWay}"
                                                       FontSize="16" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                        </Border>

                                        <!-- ARTIR -->
                                        <Button Width="38" Height="38" Background="#8E44AD" BorderThickness="0"
                                                Tag="{Binding}" Click="BtnIncrease_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock Text="+" Foreground="White" FontSize="22" FontWeight="Bold"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- SECILEN TOPLAM -->
        <Border Grid.Row="3" Background="#8E44AD" CornerRadius="12" Padding="20,14" Margin="0,12,0,8">
            <Grid>
                <TextBlock Text="Seçilen Toplam:" Foreground="White"
                           FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtSelectedTotal"
                           Text="0,00 TL" Foreground="White"
                           FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- BUTONLAR -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="İptal"
                    Style="{StaticResource SecondaryButton}"
                    Height="48" FontSize="16"
                    Click="BtnCancel_Click"/>

            <Button Grid.Column="2"
                    Style="{StaticResource PrimaryButton}"
                    Height="48" FontSize="16"
                    Click="BtnTahsilEt_Click">
                <TextBlock Text="✓ Seçileni Tahsil Et" Foreground="White" FontWeight="Bold"/>
            </Button>
        </Grid>
    </Grid>
</Window>
