<Window x:Class="EsnafPos.Views.EditProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Urunu Duzenle" Width="820" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F4F8">

    <Border Background="White" CornerRadius="14" Margin="24" Padding="40">
        <StackPanel>
            <TextBlock FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,20">
                <Run Text="Duzenle — "/>
                <Run x:Name="RunProductName" Foreground="{StaticResource AccentBrush}"/>
            </TextBlock>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Urun Adi" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}"/>
                <TextBlock Grid.Column="2" Text="Tam *" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Az" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="6" Text="1.5" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
            </Grid>

            <Grid Margin="0,0,0,36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtName"   Height="58" FontSize="17" KeyDown="Txt_KeyDown"/>
                <TextBox Grid.Column="2" x:Name="TxtTam"   Height="58" FontSize="17" KeyDown="Txt_KeyDown" TextChanged="TxtPrice_Changed"/>
                <TextBox Grid.Column="4" x:Name="TxtAz"    Height="58" FontSize="17" KeyDown="Txt_KeyDown" TextChanged="TxtPrice_Changed"/>
                <TextBox Grid.Column="6" x:Name="TxtBucuk" Height="58" FontSize="17" KeyDown="Txt_KeyDown"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel" Height="54" Padding="36,0" Margin="0,0,12,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnCancel_Click">
                    <TextBlock Text="Iptal" Foreground="White" FontWeight="SemiBold"/>
                </Button>
                <Button x:Name="BtnSave" Height="54" Padding="36,0"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnSave_Click">
                    <TextBlock Text="Kaydet" Foreground="White" FontWeight="SemiBold" FontSize="15"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
