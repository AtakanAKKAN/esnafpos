<Window x:Class="EsnafPos.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Giriş"
        Height="680" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1A2E">

    <Grid>
        <!-- KULLANICI SECIM EKRANI -->
        <StackPanel x:Name="PanelUserSelect" VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock x:Name="TxtAppName"
                       Text="Ciko POS" FontSize="38" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Kullanıcı seçin" FontSize="18"
                       Foreground="#8899AA" HorizontalAlignment="Center" Margin="0,0,0,56"/>

            <!-- Kullanici Kartlari -->
            <ItemsControl x:Name="IcUsers">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" MaxWidth="800"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="160" Height="180" Margin="16"
                                Background="Transparent" BorderThickness="0"
                                Tag="{Binding}" Click="BtnUser_Click"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CardBorder"
                                            CornerRadius="16"
                                            Background="#16213E"
                                            Padding="0">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Border Width="90" Height="90" CornerRadius="45"
                                                    Background="{StaticResource AccentBrush}"
                                                    Margin="0,0,0,16">
                                                <TextBlock Text="{Binding Username[0]}"
                                                           FontSize="38" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Username}"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock FontSize="13" Foreground="#8899AA"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0">
                                                <TextBlock.Text>
                                                    <Binding Path="Role" Converter="{x:Null}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal"/>
                                                <VisualState x:Name="MouseOver">
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="CardBorder"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#0F3460" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </VisualState>
                                                <VisualState x:Name="Pressed">
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="CardBorder"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#E94560" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- PIN EKRANI (baslangicta gizli) -->
        <Grid x:Name="PanelPin" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Background="#16213E" CornerRadius="20" Padding="48,40" Width="400">
                <StackPanel>
                    <Border Width="72" Height="72" CornerRadius="36"
                            Background="{StaticResource AccentBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock x:Name="TxtUserInitial"
                                   FontSize="30" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TxtSelectedUser"
                               FontSize="20" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtSelectedRole"
                               FontSize="14" Foreground="#8899AA"
                               HorizontalAlignment="Center" Margin="0,0,0,28"/>

                    <Border Background="#0F3460" CornerRadius="12"
                            Padding="20,16" Margin="0,0,0,8">
                        <TextBlock x:Name="TxtPinDisplay"
                                   FontSize="28" Foreground="White"
                                   HorizontalAlignment="Center" Text=""/>
                    </Border>

                    <TextBlock x:Name="TxtPinError"
                               Foreground="#E94560" FontSize="14"
                               HorizontalAlignment="Center" Margin="0,0,0,20"
                               Visibility="Collapsed"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="72"/>
                            <RowDefinition Height="72"/>
                            <RowDefinition Height="72"/>
                            <RowDefinition Height="72"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Content="1" Style="{StaticResource NumpadButton}" Click="BtnDigit_Click"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="2" Style="{StaticResource NumpadButton}" Click="BtnDigit_Click"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="3" Style="{StaticResource NumpadButton}" Click="BtnDigit_Click"/>
                        <Button Grid.Row="1" Grid.Column="0" Content="4" Style="{StaticResource NumpadButton}" Click="BtnDigit_Click"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource NumpadButton}" Click="BtnDigit_Click"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource NumpadButton}" Click="BtnDigit_Click"/>
                        <Button Grid.Row="2" Grid.Column="0" Content="7" Style="{StaticResource NumpadButton}" Click="BtnDigit_Click"/>
                        <Button Grid.Row="2" Grid.Column="1" Content="8" Style="{StaticResource NumpadButton}" Click="BtnDigit_Click"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="9" Style="{StaticResource NumpadButton}" Click="BtnDigit_Click"/>
                        <Button Grid.Row="3" Grid.Column="0" Content="⌫"
                                Style="{StaticResource NumpadButton}"
                                Foreground="#CCDDEE" Click="BtnBackspace_Click"/>
                        <Button Grid.Row="3" Grid.Column="1" Content="0" Style="{StaticResource NumpadButton}" Click="BtnDigit_Click"/>
                        <Button Grid.Row="3" Grid.Column="2" Content="✓"
                                Background="{StaticResource AccentBrush}"
                                Style="{StaticResource NumpadButton}"
                                Click="BtnLogin_Click"/>
                    </Grid>

                    <Button Content="← Kullanıcı Seç"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#8899AA" FontSize="14"
                            HorizontalAlignment="Center" Cursor="Hand"
                            Click="BtnBack_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
