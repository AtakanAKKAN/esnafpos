<Window x:Class="EsnafPos.Views.OrderHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Geçmiş Hesaplar" Height="780" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F8">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- BASLIK -->
        <TextBlock Grid.Row="0" Text="Geçmiş Hesaplar"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,10"/>

        <!-- FiLTRE -->
        <Border Grid.Row="1" Background="White" CornerRadius="14"
                Padding="16,10" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Tarih:" VerticalAlignment="Center"
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <DatePicker x:Name="DpFilter" FontSize="15" Width="160" Height="36"
                            Margin="0,0,12,0"/>
                <Button Style="{StaticResource PrimaryButton}"
                        Height="36" FontSize="13" Padding="18,0" Margin="0,0,8,0"
                        Click="BtnFilter_Click">
                    <TextBlock Text="Filtrele" Foreground="White" FontWeight="SemiBold"/>
                </Button>
                <Button Style="{StaticResource SecondaryButton}"
                        Height="36" FontSize="13" Padding="16,0"
                        Click="BtnAll_Click">
                    <TextBlock Text="Tümünü Göster" Foreground="White" FontWeight="SemiBold"/>
                </Button>
                <Border Background="#EBF5FB" CornerRadius="10" Padding="16,8" Margin="16,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="TxtCount" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- LiSTE -->
        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="IcOrders">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="14"
                                    Margin="0,0,0,14" Padding="0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2"
                                                      Color="#CCCCCC" Opacity="0.15"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Sol renk seridi -->
                                    <Border Grid.Column="0" CornerRadius="14,0,0,14">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVeresiye}" Value="True">
                                                        <Setter Property="Background" Value="#8E44AD"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <!-- Orta: detaylar -->
                                    <StackPanel Grid.Column="1" Margin="20,18,16,18">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="{Binding TableNameSnapshot}"
                                                       FontSize="19" FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,14,0"/>
                                            <Border Background="#EBF5FB" CornerRadius="8" Padding="10,5"
                                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ClosedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                                           FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
                                            </Border>
                                            <Border CornerRadius="8" Padding="10,5" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#EAFAF1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsVeresiye}" Value="True">
                                                                <Setter Property="Background" Value="#F5EEF8"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WasVeresiye}" Value="True">
                                                                <Setter Property="Background" Value="#F0E6F6"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding PaymentTypeDisplay}" FontSize="13"
                                                           FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsVeresiye}" Value="True">
                                                                    <Setter Property="Foreground" Value="#8E44AD"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding WasVeresiye}" Value="True">
                                                                    <Setter Property="Foreground" Value="#A569BD"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>

                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Background="{StaticResource LightBrush}"
                                                                CornerRadius="6" Padding="8,3" Margin="0,0,10,0">
                                                            <TextBlock Text="{Binding Quantity, StringFormat='{}{0}x'}"
                                                                       FontSize="13" FontWeight="Bold"
                                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding DisplayName, Mode=OneWay}"
                                                                   FontSize="15"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding LineTotal, StringFormat='{}{0:N2} TL', Mode=OneWay}"
                                                                   FontSize="14" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource MutedBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Sag: Toplam + Adisyon -->
                                    <Border Grid.Column="2" CornerRadius="0,14,14,0" Padding="16,18">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F8FDF9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVeresiye}" Value="True">
                                                        <Setter Property="Background" Value="#FBF5FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Toplam" FontSize="13"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N2} TL'}"
                                                       FontSize="22" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,16">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsVeresiye}" Value="True">
                                                                <Setter Property="Foreground" Value="#8E44AD"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Button Height="42" FontSize="13"
                                                    BorderThickness="0"
                                                    Tag="{Binding}"
                                                    Click="BtnPrintCheck_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
                                                        <Setter Property="Background" Value="#2980B9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsVeresiye}" Value="True">
                                                                <Setter Property="Background" Value="#8E44AD"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="Adisyon Yazdır"
                                                           Foreground="White" FontWeight="SemiBold"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Yukleniyor overlay -->
            <Border x:Name="IsBusyOverlay" Background="#80FFFFFF"
                    CornerRadius="14" Visibility="Collapsed">
                <TextBlock Text="Yükleniyor..." FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- SAYFALAMA -->
        <Border Grid.Row="3" Background="White" CornerRadius="12"
                Padding="12,8" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="BtnPrevPage"
                        Height="34" Width="100"
                        HorizontalAlignment="Left"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnPrevPage_Click">
                    <TextBlock Text="◀  Önceki" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                </Button>

                <TextBlock Grid.Column="1" x:Name="TxtPageInfo"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Margin="16,0"/>

                <Button Grid.Column="2" x:Name="BtnNextPage"
                        Height="34" Width="100"
                        HorizontalAlignment="Right"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnNextPage_Click">
                    <TextBlock Text="Sonraki  ▶" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <!-- KAPAT -->
        <Button Grid.Row="4"
                Style="{StaticResource SecondaryButton}"
                Height="48" FontSize="16" Padding="32,0"
                HorizontalAlignment="Right" Margin="0,10,0,0"
                Click="BtnClose_Click">
            <TextBlock Text="Kapat" Foreground="White" FontWeight="SemiBold"/>
        </Button>
    </Grid>
</Window>
